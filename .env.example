# Per-machine pipeline config. Copy to `.env` and edit — `.env` is git-ignored,
# so each machine can differ without merge conflicts. Loaded by scripts/config.py
# (load_dotenv). Every value here is a DEFAULT; --cli / --model flags override it.
# Uncomment and set only what you need.

# --- LLM backend -----------------------------------------------------------
# Which installed CLI drives reasoning calls: agy | claude | gemini | codex | ollama
#PW_LLM_CLI=ollama
# Model identifier recorded in every report note (and passed to agy/ollama).
# For ollama this is the `ollama run <model>` tag, e.g. ornith:9b / llama3.1.
#PW_LLM_MODEL=ornith:9b
# Fallback ollama model, used only if PW_LLM_MODEL / --model is unset (rare,
# since --model is required on the CLI).
#PW_OLLAMA_MODEL=llama3.1
# Seconds allowed per LLM call before timeout.
#PW_LLM_TIMEOUT=120

# --- Output ----------------------------------------------------------------
#PW_OUTPUT_DIR=results

# --- Pathway relevance filtering -------------------------------------------
# Hypergeometric over-representation stage.
#PW_ENRICHMENT=1
#PW_ENRICHMENT_BACKGROUND=20000
#PW_ENRICHMENT_FDR=0.05
#PW_ENRICHMENT_MIN_OVERLAP=2
# LLM relevance gate on stage-1 survivors.
#PW_LLM_GATE=1
#PW_LLM_GATE_CHUNK=40

# --- Reactome protein->protein edge extraction -----------------------------
#PW_REACTOME_EDGES=1
#PW_REACTOME_EDGE_MAX_RXN=400

# --- Cross-database consensus ----------------------------------------------
# Min distinct DBs asserting a directed edge for it to count as "robust".
#PW_ROBUST_MIN_SUPPORT=2

# --- Reflection ------------------------------------------------------------
#PW_MAX_REFLECTIONS=2
